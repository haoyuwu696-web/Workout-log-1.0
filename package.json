{
  "name": "fitlog-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:css dev:serve",
    "dev:css": "tailwindcss -i ./styles/tailwind.css -o ./styles/output.css --watch",
    "dev:serve": "live-server . --port=5173 --no-browser",
    "build:css": "tailwindcss -i ./styles/tailwind.css -o ./styles/output.css --minify",
    "build:site": "node scripts/build-site.js",
    "preview": "live-server . --port=5173 --no-browser"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16"
  }
}
